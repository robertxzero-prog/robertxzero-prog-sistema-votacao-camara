PORT=3000
JWT_SECRET=CHANGE_ME_TO_A_STRONG_SECRET
JWT_EXPIRES_IN=8h
PUBLIC_API_BASE_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3001,http://localhost:55235

# Seguranca de login (anti-forca-bruta)
AUTH_MAX_FALHAS=5
AUTH_JANELA_MINUTOS=10
AUTH_BLOQUEIO_MINUTOS=15
MAX_ACTIVE_SESSIONS_PER_USER=3
ENFORCE_2FA=true

# Licenciamento e onboarding SaaS
REQUIRE_SAAS_ACTIVATION=true
CAMARA_INSTANCE_CODE=default
MASTER_API_URL=http://localhost:3000
ONBOARDING_SHARED_KEY=CHANGE_ME_ONBOARDING_KEY
DEFAULT_INSTANCE_BACKEND_URL=http://localhost:3000
MONITOR_TOKEN_SALT=CHANGE_ME_MONITOR_SALT
MASTER_INSTANCE_ADMIN_KEY=CHANGE_ME_MASTER_INSTANCE_ADMIN_KEY
LOCAL_MASTER_ADMIN_KEY=CHANGE_ME_MASTER_INSTANCE_ADMIN_KEY

# Alerta por e-mail quando nova camara for cadastrada
RESEND_API_KEY=
SAAS_ALERT_EMAIL_TO=robertxzero@gmail.com
SAAS_ALERT_EMAIL_FROM=onboarding@seudominio.com
SAAS_MASTER_WEB_URL=https://votacam-master-web.onrender.com
